{
  "version": 2,
  "name": "ai-browser",
  "rewrites": [
    {
      "source": "/(signup|login|me|logout|news|command|transcribe)",
      "destination": "/api/index.py"
    },
    {
      "source": "/",
      "destination": "/frontend/login.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}